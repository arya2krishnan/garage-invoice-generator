# Resend API key for the email-invoice endpoint. Free tier at resend.com.
# Leave unset to disable email delivery (downloads still work).
RESEND_API_KEY=re_your_key_here

# Bearer token for Garage's protected endpoints (warranty quotes + freight
# shipping quotes). If unset, those line items are simply omitted from the
# invoice and the base download still works.
GARAGE_API_TOKEN=your_jwt_here
